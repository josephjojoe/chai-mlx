digraph TokenInputEmbedder {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled",
          fillcolor="#f7f7f7", color="#333333", penwidth=1.2, margin="0.12,0.06"];
    edge [fontname="Helvetica", fontsize=9, color="#555555", penwidth=1.0];
    graph [bgcolor="transparent", pad="0.3", nodesep=0.45, ranksep=0.5];

    label=<<B>Token Input Embedder</B><BR/><FONT POINT-SIZE="9">token_embedder.pt  (~1.5M params)</FONT>>;
    labelloc=t; fontsize=13;

    // Inputs
    token_single [label=<<B>token_single_input_feats</B><BR/>[b, n_tokens, 384]>,
                  fillcolor="#e3f2fd"];
    atom_single [label=<<B>atom_single_input_feats</B><BR/>[b, n_atoms, 128]>,
                 fillcolor="#e3f2fd"];
    atom_pair [label=<<B>block_atom_pair_feat</B><BR/>[b, bl, 32, 128, 16]>,
               fillcolor="#e3f2fd"];
    pair_feat [label=<<B>token_pair_input_feats</B><BR/>[b, n_tokens, n_tokens, 256]>,
               fillcolor="#e3f2fd"];

    // Atom conditioning
    atom_cond [label=<<B>to_atom_cond</B><BR/>Linear(128, 128)>,
               fillcolor="#fff3e0"];

    // Pair update
    pair_update [label=<<B>Pair Update Block</B><BR/><FONT POINT-SIZE="8">proj_h: Linear(128, 16)<BR/>proj_w: Linear(128, 16)<BR/>MLP: Linear(16,16) → Linear(16,16)</FONT>>,
                 fillcolor="#fff3e0"];

    // Atom transformer
    subgraph cluster_atom_transformer {
        label=<<B>LocalDiffusionTransformer (3 blocks)</B>>;
        style="dashed"; color="#999999"; fontsize=10;
        node [fillcolor="#e8eaf6"];

        pair_bias [label=<<B>blocked_pairs2blocked_bias</B><BR/><FONT POINT-SIZE="8">LN(16) → Linear(16, 12)<BR/>3 blocks × 4 heads</FONT>>];

        attn1 [label=<<B>LocalAttentionPairBiasBlock ×3</B><BR/><FONT POINT-SIZE="8">4 heads, 32 head_dim<BR/>AdaLN conditioned, 128-dim</FONT>>];

        trans1 [label=<<B>ConditionedTransitionBlock ×3</B><BR/><FONT POINT-SIZE="8">SwiGLU, 4× expansion<BR/>sigmoid gate (bias init −2)</FONT>>];
    }

    // Aggregation
    to_token [label=<<B>to_token_single</B><BR/>Linear(128, 384, no bias)>,
              fillcolor="#fff3e0"];
    aggregate [label=<<B>Aggregate</B><BR/><FONT POINT-SIZE="8">scatter by atom_token_indices<BR/>atom-level → token-level</FONT>>,
               fillcolor="#fce4ec", shape=diamond];

    concat [label=<<B>Concatenate</B><BR/>[token_single(384) ++ atom_agg(384)] = 768>,
            fillcolor="#f3e5f5"];

    // Output projections
    proj_trunk [label=<<B>token_single_proj_in_trunk</B><BR/>Linear(768, 384, no bias)>,
                fillcolor="#e8f5e9"];
    proj_struct [label=<<B>token_single_proj_in_structure</B><BR/>Linear(768, 384, no bias)>,
                 fillcolor="#e8f5e9"];

    // Pair output
    pair_proj [label=<<B>token_pair_proj_in_trunk</B><BR/>Linear(256, 256, no bias)<BR/>+ outer_sum from Linear(384, 512)>,
               fillcolor="#e8f5e9"];

    // Output nodes
    out_single_init [label=<<B>token_single_initial_repr</B><BR/>[b, n_tokens, 384]>,
                     fillcolor="#c8e6c9"];
    out_single_struct [label=<<B>token_single_structure_input</B><BR/>[b, n_tokens, 384]>,
                       fillcolor="#c8e6c9"];
    out_pair_init [label=<<B>token_pair_initial_repr</B><BR/>[b, n_tokens, n_tokens, 256]>,
                   fillcolor="#c8e6c9"];

    // Edges
    atom_single -> atom_cond;
    atom_single -> pair_update;
    atom_pair -> pair_update;
    pair_update -> pair_bias;
    atom_cond -> attn1 [label="conditioning"];
    pair_bias -> attn1 [label="attn bias"];
    attn1 -> trans1;
    atom_cond -> trans1 [label="gating"];
    trans1 -> to_token;
    to_token -> aggregate;
    token_single -> concat;
    aggregate -> concat;
    concat -> proj_trunk;
    concat -> proj_struct;
    proj_trunk -> out_single_init;
    proj_struct -> out_single_struct;
    pair_feat -> pair_proj;
    proj_trunk -> pair_proj [label="outer sum", style=dashed];
    pair_proj -> out_pair_init;
}
