digraph FeatureEmbedding {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled",
          fillcolor="#f7f7f7", color="#333333", penwidth=1.2, margin="0.12,0.06"];
    edge [fontname="Helvetica", fontsize=9, color="#555555", penwidth=1.0];
    graph [bgcolor="transparent", pad="0.3", nodesep=0.4, ranksep=0.55];

    label=<<B>Feature Embedding Module</B><BR/><FONT POINT-SIZE="9">feature_embedding.pt  (~1.1M params)</FONT>>;
    labelloc=t; fontsize=13;

    subgraph cluster_inputs {
        label=<<B>32 Named Features (Raw Inputs)</B>>;
        style="dashed"; color="#999999"; fontsize=10;
        node [fillcolor="#e3f2fd"];

        token_raw [label=<<B>TOKEN</B><BR/>2638-dim<BR/><FONT POINT-SIZE="8">ResidueType(33) + ESM(2560)<BR/>MSAProfile(32) + DelMean(1) + ...</FONT>>];
        pair_raw [label=<<B>TOKEN_PAIR</B><BR/>163-dim<BR/><FONT POINT-SIZE="8">RelSeqSep(67) + RelTokSep(67)<BR/>RelEntity(3) + RelChain(6) + ...</FONT>>];
        atom_raw [label=<<B>ATOM</B><BR/>395-dim<BR/><FONT POINT-SIZE="8">AtomName(260) + RefCharge(1)<BR/>RefElement(130) + RefMask(1) + RefPos(3)</FONT>>];
        atompair_raw [label=<<B>ATOM_PAIR</B><BR/>14-dim<BR/><FONT POINT-SIZE="8">Distogram(12) + InvSqDist(2)</FONT>>];
        msa_raw [label=<<B>MSA</B><BR/>42-dim<BR/><FONT POINT-SIZE="8">OneHot(32) + HasDel(1) + DelVal(1)<BR/>IsPaired(1) + DataSource(7)</FONT>>];
        template_raw [label=<<B>TEMPLATES</B><BR/>76-dim<BR/><FONT POINT-SIZE="8">Mask(2) + UnitVec(3) + ResType(32)<BR/>Distogram(39)</FONT>>];
    }

    subgraph cluster_projections {
        label=<<B>Type-Specific Input Projections (Linear + bias)</B>>;
        style="dashed"; color="#999999"; fontsize=10;
        node [fillcolor="#fff3e0"];

        proj_token [label=<<B>Linear(2638, 384)</B>>];
        proj_pair [label=<<B>Linear(163, 512)</B>>];
        proj_atom [label=<<B>Linear(395, 256)</B>>];
        proj_atompair [label=<<B>Linear(14, 32)</B>>];
        proj_msa [label=<<B>Linear(42, 64)</B>>];
        proj_template [label=<<B>Linear(76, 64)</B>>];
    }

    subgraph cluster_outputs {
        label=<<B>Embedded Representations</B>>;
        style="dashed"; color="#999999"; fontsize=10;
        node [fillcolor="#e8f5e9"];

        out_token [label=<<B>TOKEN</B><BR/>384>];

        out_pair_trunk [label=<<B>TOKEN_PAIR (trunk)</B><BR/>256>];
        out_pair_struct [label=<<B>TOKEN_PAIR (structure)</B><BR/>256>];

        out_atom_trunk [label=<<B>ATOM (trunk)</B><BR/>128>];
        out_atom_struct [label=<<B>ATOM (structure)</B><BR/>128>];

        out_atompair_trunk [label=<<B>ATOM_PAIR (trunk)</B><BR/>16>];
        out_atompair_struct [label=<<B>ATOM_PAIR (structure)</B><BR/>16>];

        out_msa [label=<<B>MSA</B><BR/>64>];
        out_template [label=<<B>TEMPLATES</B><BR/>64>];
    }

    token_raw -> proj_token;
    pair_raw -> proj_pair;
    atom_raw -> proj_atom;
    atompair_raw -> proj_atompair;
    msa_raw -> proj_msa;
    template_raw -> proj_template;

    proj_token -> out_token;

    proj_pair -> out_pair_trunk [label="chunk(2)"];
    proj_pair -> out_pair_struct [label="chunk(2)"];

    proj_atom -> out_atom_trunk [label="chunk(2)"];
    proj_atom -> out_atom_struct [label="chunk(2)"];

    proj_atompair -> out_atompair_trunk [label="chunk(2)"];
    proj_atompair -> out_atompair_struct [label="chunk(2)"];

    proj_msa -> out_msa;
    proj_template -> out_template;
}
