digraph TemplateEmbedder {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled",
          fillcolor="#f7f7f7", color="#333333", penwidth=1.2, margin="0.12,0.06"];
    edge [fontname="Helvetica", fontsize=9, color="#555555", penwidth=1.0];
    graph [bgcolor="transparent", pad="0.3", nodesep=0.4, ranksep=0.5];

    label=<<B>Template Embedder</B><BR/><FONT POINT-SIZE="9">Within trunk.pt — processes up to 4 structural templates</FONT>>;
    labelloc=t; fontsize=13;

    // Inputs
    template_feats [label=<<B>Template Features</B><BR/>[b, 4, n, n, 64]<BR/><FONT POINT-SIZE="8">Mask(2), UnitVec(3), ResType(32), Distogram(39)</FONT>>,
                    fillcolor="#e3f2fd"];
    pair_repr [label=<<B>Pair Representation</B><BR/>[b, n, n, 256]>,
               fillcolor="#e3f2fd"];

    // Projection in
    proj_in [label=<<B>proj_in</B><BR/>LN(256) → Linear(256, 64, no bias)>,
             fillcolor="#fff3e0"];

    // Pairformer blocks
    subgraph cluster_pairformer {
        label=<<B>2× PairformerBlock (dim 64)</B>>;
        style="dashed"; color="#999999"; fontsize=10;
        node [fillcolor="#e8eaf6"];

        transition [label=<<B>transition_pair</B><BR/><FONT POINT-SIZE="8">LN(64) → SwiGLU(64→256→128→64)</FONT>>];
        tri_mult [label=<<B>triangle_multiplication</B><BR/><FONT POINT-SIZE="8">LN(64) → merged_linear_p(64,256)<BR/>merged_linear_g(64,320) → sigmoid gate<BR/>outgoing + incoming contractions<BR/>linear_z_out(64, 64)</FONT>>];
        tri_attn [label=<<B>triangle_attention</B><BR/><FONT POINT-SIZE="8">pair2b: Linear(64, 8) → 8 heads bias<BR/>pair2qkvg1: Linear(64, 512) → starting node<BR/>pair2qkvg2: Linear(64, 512) → ending node<BR/>linear_out: Linear(256, 64)</FONT>>];
    }

    // Output projection
    template_ln [label=<<B>template_layernorm</B><BR/>LayerNorm(64)>,
                 fillcolor="#fff3e0"];
    proj_out [label=<<B>proj_out</B><BR/>Linear(64, 256, no bias)>,
              fillcolor="#fff3e0"];

    // Add
    add [label=<+>, shape=circle, fillcolor="#e8f5e9", fixedsize=true, width=0.4];

    // Output
    pair_out [label=<<B>Updated Pair Representation</B><BR/>[b, n, n, 256]>,
              fillcolor="#c8e6c9"];

    // Edges
    template_feats -> transition;
    transition -> tri_mult;
    tri_mult -> tri_attn;
    tri_attn -> template_ln;
    template_ln -> proj_out;
    pair_repr -> proj_in;
    proj_in -> add [style=dashed, label="projected pair\nbroadcast to templates"];
    proj_out -> add;
    add -> pair_out;
}
