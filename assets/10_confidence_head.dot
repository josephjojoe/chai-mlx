digraph ConfidenceHead {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled",
          fillcolor="#f7f7f7", color="#333333", penwidth=1.2, margin="0.12,0.06"];
    edge [fontname="Helvetica", fontsize=9, color="#555555", penwidth=1.0];
    graph [bgcolor="transparent", pad="0.3", nodesep=0.4, ranksep=0.5];

    label=<<B>Confidence Head</B><BR/><FONT POINT-SIZE="9">confidence_head.pt  (~14.8M params)</FONT>>;
    labelloc=t; fontsize=13;

    // Inputs
    single_repr [label=<<B>single_repr</B><BR/>[b, n, 384]>,
                 fillcolor="#e3f2fd"];
    pair_repr [label=<<B>pair_repr</B><BR/>[b, n, n, 256]>,
               fillcolor="#e3f2fd"];
    atom_coords [label=<<B>Predicted atom coords</B><BR/>[b, n_atoms, 3]>,
                 fillcolor="#e3f2fd"];

    // Input processing
    outer_sum [label=<<B>Pair Initialization</B><BR/><FONT POINT-SIZE="8">single_to_pair_proj: Linear(384, 512)<BR/>chunk → 2×256, outer sum</FONT>>,
               fillcolor="#fff3e0"];
    dist_bins [label=<<B>Distance Binning</B><BR/><FONT POINT-SIZE="8">Pairwise atom distances<BR/>searchsorted into 16 bins</FONT>>,
               fillcolor="#fff3e0"];
    dist_proj [label=<<B>atom_distance_bins_projection</B><BR/>Linear(16, 256, no bias)>,
               fillcolor="#fff3e0"];

    add_pair [label=<+>, shape=circle, fillcolor="#e8f5e9", fixedsize=true, width=0.4];

    // Pairformer blocks
    subgraph cluster_pairformer {
        label=<<B>4× Pairformer Block</B>>;
        style="dashed"; color="#999999"; fontsize=10;
        node [fillcolor="#e8eaf6"];

        pair_trans [label=<<B>transition_pair</B><BR/><FONT POINT-SIZE="8">SwiGLU 4× at dim 256</FONT>>];
        attn_pb [label=<<B>attention_pair_bias</B><BR/><FONT POINT-SIZE="8">16 heads, 24 head_dim (same as trunk)</FONT>>];
        single_trans [label=<<B>transition_single</B><BR/><FONT POINT-SIZE="8">SwiGLU 4× at dim 384</FONT>>];
        tri_mult [label=<<B>triangle_multiplication</B><BR/><FONT POINT-SIZE="8">sigmoid-gated, both directions</FONT>>];
        tri_attn [label=<<B>triangle_attention</B><BR/><FONT POINT-SIZE="8">Fused: pair2qkvgb Linear(256, 2056)<BR/>8 heads × 64 head_dim<BR/>(different from trunk's 32 head_dim)</FONT>>];
    }

    // Output heads
    subgraph cluster_outputs {
        label=<<B>Output Heads</B>>;
        style="dashed"; color="#999999"; fontsize=10;
        node [fillcolor="#c8e6c9"];

        plddt [label=<<B>pLDDT Head</B><BR/><FONT POINT-SIZE="8">Linear(384, 1850)<BR/>→ [b, n_tok, 37, 50] → [b, n_atoms, 50]<BR/>50 bins over [0, 1]</FONT>>];
        pae [label=<<B>PAE Head</B><BR/><FONT POINT-SIZE="8">Linear(256, 64)<BR/>→ [b, n_tok, n_tok, 64]<BR/>64 bins over [0, 32]Å</FONT>>];
        pde [label=<<B>PDE Head</B><BR/><FONT POINT-SIZE="8">Linear(256, 64)<BR/>→ [b, n_tok, n_tok, 64]<BR/>64 bins over [0, 32]Å</FONT>>];
    }

    // Edges
    single_repr -> outer_sum;
    pair_repr -> add_pair;
    outer_sum -> add_pair;
    atom_coords -> dist_bins;
    dist_bins -> dist_proj;
    dist_proj -> add_pair;
    add_pair -> pair_trans;
    single_repr -> attn_pb;
    pair_trans -> attn_pb;
    attn_pb -> single_trans;
    single_trans -> tri_mult [style=invis];
    pair_trans -> tri_mult;
    tri_mult -> tri_attn;

    single_trans -> plddt;
    tri_attn -> pae;
    tri_attn -> pde;
}
