digraph DiffusionModule {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled",
          fillcolor="#f7f7f7", color="#333333", penwidth=1.2, margin="0.12,0.06"];
    edge [fontname="Helvetica", fontsize=9, color="#555555", penwidth=1.0];
    graph [bgcolor="transparent", pad="0.3", nodesep=0.4, ranksep=0.5];

    label=<<B>Diffusion Module</B><BR/><FONT POINT-SIZE="9">diffusion_module.pt  (~128M params, ×200 denoising steps)</FONT>>;
    labelloc=t; fontsize=13;

    // Inputs
    single_init [label=<<B>token_single_initial</B><BR/>[b, n, 384]>,
                 fillcolor="#e3f2fd"];
    single_trunk [label=<<B>token_single_trunk</B><BR/>[b, n, 384]>,
                  fillcolor="#e3f2fd"];
    pair_init [label=<<B>token_pair_initial</B><BR/>[b, n, n, 256]>,
               fillcolor="#e3f2fd"];
    pair_trunk [label=<<B>token_pair_trunk</B><BR/>[b, n, n, 256]>,
                fillcolor="#e3f2fd"];
    sigma [label=<<B>σ (noise level)</B>>,
           fillcolor="#fff9c4", shape=oval];
    noised_pos [label=<<B>Noised atom positions</B><BR/>[b, n_atoms, 3]>,
                fillcolor="#fff9c4", shape=oval];
    atom_feats [label=<<B>Atom features</B><BR/><FONT POINT-SIZE="8">single[128], pair[16]<BR/>structure inputs</FONT>>,
                fillcolor="#e3f2fd"];

    // Conditioning
    subgraph cluster_conditioning {
        label=<<B>Diffusion Conditioning</B>>;
        style="dashed"; color="#999999"; fontsize=10;
        node [fillcolor="#fff3e0"];

        concat_single [label=<<B>Concat + Proj</B><BR/><FONT POINT-SIZE="8">[384++384] = 768<BR/>LN(768) → Linear(768, 384)</FONT>>];
        fourier [label=<<B>Fourier Embedding</B><BR/><FONT POINT-SIZE="8">cos(W·log(σ) + b) → 256-dim<BR/>LN(256) → Linear(256, 384)</FONT>>];
        single_trans [label=<<B>2× SwiGLU Transition</B><BR/><FONT POINT-SIZE="8">dim 384, 4× expansion<BR/>+ Fourier between blocks</FONT>>];
        s_cond [label=<<B>s_cond</B><BR/>LN(384) → [b, n, 384]>,
                fillcolor="#c8e6c9"];

        concat_pair [label=<<B>Concat + Proj</B><BR/><FONT POINT-SIZE="8">[256++256] = 512<BR/>LN(512) → Linear(512, 256)</FONT>>];
        pair_trans [label=<<B>2× SwiGLU Transition</B><BR/><FONT POINT-SIZE="8">dim 256, 4× expansion</FONT>>];
        z_cond [label=<<B>z_cond</B><BR/>LN(256) → [b, n, n, 256]>,
                fillcolor="#c8e6c9"];
    }

    // Encoder
    encoder [label=<<B>Atom Attention Encoder</B><BR/><FONT POINT-SIZE="8">3 local attn blocks (4 heads, 32 hd, dim 128)<BR/>+ prev_pos_embed: Linear(3, 128)<BR/>+ token_pair_to_atom_pair: LN(256) → Linear(256, 16)<BR/>→ to_token_single: Linear(128, 768)</FONT>>,
             fillcolor="#e8eaf6"];

    // Structure conditioning
    struct_proj [label=<<B>structure_cond_to_token_structure_proj</B><BR/>Linear(384, 768, no bias)>,
                 fillcolor="#fff3e0"];

    // Diffusion transformer
    diff_transformer [label=<<B>Diffusion Transformer (16 blocks)</B><BR/><FONT POINT-SIZE="8">16 heads, 48 head_dim, 768 working dim<BR/>AdaLN conditioned by s_cond[384]<BR/>Pair bias from z_cond[256]<BR/>SwiGLU transition, sigmoid gate (bias −2)</FONT>>,
                      fillcolor="#f3e5f5"];

    // Decoder
    decoder [label=<<B>Atom Attention Decoder</B><BR/><FONT POINT-SIZE="8">token_to_atom: Linear(768, 128)<BR/>3 local attn blocks (4 heads, 32 hd)<BR/>to_pos_updates: LN(128) → Linear(128, 3)</FONT>>,
             fillcolor="#e8eaf6"];

    // Output
    output [label=<<B>Denoised atom coordinates</B><BR/>[b, n_atoms, 3]>,
            fillcolor="#c8e6c9", shape=oval];

    // Conditioning edges
    single_init -> concat_single;
    single_trunk -> concat_single;
    concat_single -> single_trans;
    sigma -> fourier;
    fourier -> single_trans [label="+ added"];
    single_trans -> s_cond;

    pair_init -> concat_pair;
    pair_trunk -> concat_pair;
    concat_pair -> pair_trans;
    pair_trans -> z_cond;

    // Main path
    atom_feats -> encoder;
    noised_pos -> encoder;
    z_cond -> encoder [label="atom pair bias"];
    s_cond -> encoder [label="conditioning"];
    encoder -> diff_transformer [label="token repr [768]"];
    struct_proj -> diff_transformer [label="+ structure cond", style=dashed];
    s_cond -> diff_transformer [label="AdaLN cond"];
    z_cond -> diff_transformer [label="pair bias"];
    diff_transformer -> decoder;
    s_cond -> decoder [style=dashed, label="conditioning"];
    decoder -> output;
}
