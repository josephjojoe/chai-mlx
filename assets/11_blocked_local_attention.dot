digraph BlockedLocalAttention {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled",
          fillcolor="#f7f7f7", color="#333333", penwidth=1.2, margin="0.12,0.06"];
    edge [fontname="Helvetica", fontsize=9, color="#555555", penwidth=1.0];
    graph [bgcolor="transparent", pad="0.3", nodesep=0.4, ranksep=0.5];

    label=<<B>Blocked Local Attention Scheme</B><BR/><FONT POINT-SIZE="9">Atom-level attention with fixed local windows</FONT>>;
    labelloc=t; fontsize=13;

    // Layout description
    subgraph cluster_geometry {
        label=<<B>Block Geometry</B>>;
        style="dashed"; color="#999999"; fontsize=10;
        node [fillcolor="#e8eaf6"];

        atoms [label=<<B>Atom Sequence</B><BR/><FONT POINT-SIZE="8">n_atoms = 23 × n_tokens<BR/>enforced divisible by 32</FONT>>];

        query_block [label=<<B>Query Block</B><BR/><FONT POINT-SIZE="8">32 atoms (non-overlapping, consecutive)<BR/>num_blocks = n_atoms / 32</FONT>>,
                     fillcolor="#fff3e0"];

        kv_window [label=<<B>KV Window</B><BR/><FONT POINT-SIZE="8">128 atoms, centered on query block<BR/>kv_start = query_start − 48<BR/>Query sits at positions 48–79 in window</FONT>>,
                   fillcolor="#e8f5e9"];

        overlap [label=<<B>Overlap</B><BR/><FONT POINT-SIZE="8">Consecutive KV windows share 96 atoms<BR/>(shift 32, window 128)</FONT>>,
                 fillcolor="#fff9c4"];
    }

    subgraph cluster_boundary {
        label=<<B>Boundary Handling</B>>;
        style="dashed"; color="#999999"; fontsize=10;
        node [fillcolor="#fce4ec"];

        boundary [label=<<B>Modular Wrap</B><BR/><FONT POINT-SIZE="8">KV indices below 0 or above n_atoms<BR/>marked invalid in kv_mask<BR/>taken % n_atoms for indexing only</FONT>>];

        mask [label=<<B>Block Pair Mask</B><BR/><FONT POINT-SIZE="8">atom_q_mask ⊗ atom_kv_mask<BR/>AND with kv_is_wrapped_mask<BR/>→ [b, bl, 32, 128]</FONT>>];
    }

    subgraph cluster_pair_tensor {
        label=<<B>Pair Tensor Layout</B>>;
        style="dashed"; color="#999999"; fontsize=10;
        node [fillcolor="#e3f2fd"];

        layout [label=<<B>Pair Features</B><BR/>[b, num_blocks, 32, 128, feat_dim]<BR/><FONT POINT-SIZE="8">block idx, query slot, key slot, channels</FONT>>];

        bias [label=<<B>blocked_pairs2blocked_bias</B><BR/><FONT POINT-SIZE="8">LN(feat_dim) → Linear(feat_dim, n_blocks × n_heads)<BR/>→ per-head attention bias per local block</FONT>>,
              fillcolor="#fff3e0"];
    }

    subgraph cluster_usage {
        label=<<B>Used In</B>>;
        style="dashed"; color="#999999"; fontsize=10;
        node [fillcolor="#f3e5f5"];

        tok_embed [label=<<B>Token Embedder</B><BR/><FONT POINT-SIZE="8">3 blocks, 4 heads, 32 hd<BR/>dim 128</FONT>>];
        diff_encoder [label=<<B>Diffusion Encoder</B><BR/><FONT POINT-SIZE="8">3 blocks, 4 heads, 32 hd<BR/>dim 128</FONT>>];
        diff_decoder [label=<<B>Diffusion Decoder</B><BR/><FONT POINT-SIZE="8">3 blocks, 4 heads, 32 hd<BR/>dim 128</FONT>>];
    }

    // Edges
    atoms -> query_block;
    atoms -> kv_window;
    query_block -> overlap;
    kv_window -> overlap;
    kv_window -> boundary;
    boundary -> mask;
    layout -> bias;
    bias -> tok_embed;
    bias -> diff_encoder;
    bias -> diff_decoder;
}
