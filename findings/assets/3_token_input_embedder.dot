digraph token_input_embedder {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box];
    edge [fontname="Helvetica", fontsize=8];
    bgcolor="white";
    pad=0.4;
    nodesep=0.3;
    ranksep=0.45;

    // ── Inputs ──
    in_tok [label="token_single_input\n[b, n_tokens, 384]", fillcolor="#E3F2FD", color="#1565C0"];
    in_atom [label="atom_single_input\n[b, n_atoms, 128]", fillcolor="#E3F2FD", color="#1565C0"];
    in_pair [label="block_atom_pair_feat\n[b, bl, 32, 128, 16]", fillcolor="#E3F2FD", color="#1565C0"];

    // ── Atom Conditioning ──
    cond [label="to_atom_cond\nLinear(128, 128)", fillcolor="#FFF9C4", color="#F9A825"];

    // ── Pair Update Block ──
    subgraph cluster_pair_update {
        label="Pair Update Block (runs once)"; labeljust=l;
        style="filled,rounded"; fillcolor="#FFF3E0"; color="#E65100"; fontsize=10; margin=12;

        proj_h [label="proj_h: LN(128) → Linear(128, 16)\nquery atoms → [b, bl, 32, 16]", fillcolor="#FFE0B2", color="#E65100"];
        proj_w [label="proj_w: LN(128) → Linear(128, 16)\nkey atoms → [b, bl, 128, 16]", fillcolor="#FFE0B2", color="#E65100"];
        outer_add [label="pair += h[:,None,:] + w[:,:,None]\nouter-sum addition", fillcolor="#FFCC80", color="#E65100"];
        mlp [label="pair += MLP(pair)\nLinear(16,16) → ReLU → Linear(16,16)", fillcolor="#FFE0B2", color="#E65100"];
    }

    // ── Local Attention Blocks ──
    subgraph cluster_attn {
        label="Local Diffusion Transformer  ×3 blocks"; labeljust=l;
        style="filled,rounded"; fillcolor="#E8F5E9"; color="#2E7D32"; fontsize=10; margin=12;

        pair_bias [label="blocked_pairs2blocked_bias\nLN(16) → Linear(16, 12)\n3 blocks × 4 heads = 12 bias channels", fillcolor="#C8E6C9", color="#2E7D32"];
        attn_block [label="LocalAttentionPairBiasBlock\n4 heads, 32 head_dim\nAdaLN conditioning\nQ block=32, KV window=128", fillcolor="#A5D6A7", color="#2E7D32"];
        trans_block [label="ConditionedTransitionBlock\nAdaLN → SwiGLU (4×)\nSigmoid gate (bias init -2)", fillcolor="#C8E6C9", color="#2E7D32"];
    }

    // ── Aggregation ──
    to_tok [label="to_token_single\nLinear(128, 384, no bias)", fillcolor="#E1BEE7", color="#7B1FA2"];
    agg [label="Masked Mean Aggregation\nscatter_reduce(\"sum\") by atom_token_index\n÷ count per token\n→ [b, n_tokens, 384]", fillcolor="#E1BEE7", color="#7B1FA2"];
    concat [label="Concatenate\n[token_single (384) ‖ atom_agg (384)]\n→ [b, n_tokens, 768]", fillcolor="#CE93D8", color="#6A1B9A"];

    // ── Output projections ──
    proj_trunk [label="Linear(768, 384, no bias)\n→ single_initial", fillcolor="#C5CAE9", color="#283593"];
    proj_struct [label="Linear(768, 384, no bias)\n→ single_structure", fillcolor="#C5CAE9", color="#283593"];

    // ── Pair output ──
    s2p [label="single_to_pair: Linear(384, 512, no bias)\nchunk → half_row[256] + half_col[256]", fillcolor="#B2DFDB", color="#00695C"];
    pair_out [label="pair[i,j] = pair_input[i,j]\n+ half_row[i] + half_col[j]", fillcolor="#B2DFDB", color="#00695C"];
    pair_proj [label="Linear(256, 256, no bias)\n→ pair_initial", fillcolor="#C5CAE9", color="#283593"];

    // ── Outputs ──
    out_si [label="single_initial\n[b, n, 384]", fillcolor="#F5F5F5", color="#424242", shape=box];
    out_ss [label="single_structure\n[b, n, 384]", fillcolor="#F5F5F5", color="#424242", shape=box];
    out_pi [label="pair_initial\n[b, n, n, 256]", fillcolor="#F5F5F5", color="#424242", shape=box];

    // ── Edges ──
    in_atom -> cond;
    cond -> proj_h;
    cond -> proj_w;
    in_pair -> outer_add;
    proj_h -> outer_add;
    proj_w -> outer_add;
    outer_add -> mlp;
    mlp -> pair_bias [lhead=cluster_attn];

    in_atom -> attn_block [label="atom repr"];
    pair_bias -> attn_block [label="per-head bias"];
    attn_block -> trans_block;
    trans_block -> to_tok [label="atom repr\n[b, n_atoms, 128]"];

    to_tok -> agg;
    in_tok -> concat;
    agg -> concat;

    concat -> proj_trunk;
    concat -> proj_struct;

    proj_trunk -> out_si;
    proj_struct -> out_ss;

    proj_trunk -> s2p;
    s2p -> pair_out;
    pair_out -> pair_proj;
    pair_proj -> out_pi;
}
