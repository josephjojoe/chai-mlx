digraph diffusion_module {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box];
    edge [fontname="Helvetica", fontsize=8];
    bgcolor="white";
    pad=0.4;
    nodesep=0.3;
    ranksep=0.45;

    // ── External Inputs ──
    in_s_init [label="single_structure [384]", fillcolor="#E3F2FD", color="#1565C0"];
    in_s_trunk [label="single_trunk [384]", fillcolor="#E3F2FD", color="#1565C0"];
    in_z_init [label="pair_structure [256]", fillcolor="#E3F2FD", color="#1565C0"];
    in_z_trunk [label="pair_trunk [256]", fillcolor="#E3F2FD", color="#1565C0"];
    in_sigma [label="σ (noise level)", fillcolor="#FFECB3", color="#FF8F00", shape=ellipse];
    in_noised [label="noised atom coords\n[b, ds, n_atoms, 3]", fillcolor="#FFECB3", color="#FF8F00"];
    in_atom_feats [label="atom_single_struct [128]\nblock_atom_pair_struct [16]", fillcolor="#E3F2FD", color="#1565C0"];

    // ── Diffusion Conditioning ──
    subgraph cluster_cond {
        label="Diffusion Conditioning"; labeljust=l;
        style="filled,rounded"; fillcolor="#FFF3E0"; color="#E65100"; fontsize=10; margin=12;

        cat_s [label="concat [384 ‖ 384] = 768\nLN(768) → Linear(768, 384, no bias)", fillcolor="#FFE0B2", color="#E65100"];
        s_trans1 [label="single_trans1\nSwiGLU (4×)", fillcolor="#FFE0B2", color="#E65100"];

        fourier [label="Fourier Embedding\ncos(w·ln(σ)/4 + b) · 2π → 256-d\n→ LN(256) → Linear(256, 384)", fillcolor="#FFCC80", color="#E65100"];

        s_trans2 [label="single_trans2\nSwiGLU (4×)", fillcolor="#FFE0B2", color="#E65100"];
        s_ln [label="LN(384) → s_cond", fillcolor="#FFE0B2", color="#E65100"];

        cat_z [label="concat [256 ‖ 256] = 512\nLN(512) → Linear(512, 256, no bias)", fillcolor="#FFE0B2", color="#E65100"];
        z_trans [label="pair_trans1 → pair_trans2\n2× SwiGLU (4×)", fillcolor="#FFE0B2", color="#E65100"];
        z_ln [label="LN(256) → z_cond", fillcolor="#FFE0B2", color="#E65100"];
    }

    // ── Atom Attention Encoder ──
    subgraph cluster_enc {
        label="Atom Attention Encoder"; labeljust=l;
        style="filled,rounded"; fillcolor="#E8F5E9"; color="#2E7D32"; fontsize=10; margin=12;

        tok2atom [label="token_to_atom_single\nLN(384) → Linear(384, 128)\nbroadcast token → atom", fillcolor="#C8E6C9", color="#2E7D32"];
        prev_pos [label="prev_pos_embed\nLinear(3, 128, no bias)\nembeds noised coords", fillcolor="#C8E6C9", color="#2E7D32"];
        pair2ap [label="token_pair_to_atom_pair\nLN(256) → Linear(256, 16)", fillcolor="#C8E6C9", color="#2E7D32"];
        enc_pair_upd [label="Pair Update Block\nouter-sum + MLP (dim 16)", fillcolor="#C8E6C9", color="#2E7D32"];
        enc_attn [label="3× Local Attention Blocks\n4 heads, 32 head_dim\n+ 3× Conditioned Transitions\n(blocked Q=32, KV=128)", fillcolor="#A5D6A7", color="#1B5E20"];
        enc_agg [label="to_token_single\nLinear(128, 768, no bias)\n+ masked mean aggregation\n→ [b, n_tokens, 768]", fillcolor="#C8E6C9", color="#2E7D32"];
    }

    // ── Diffusion Transformer ──
    subgraph cluster_xfmr {
        label="Diffusion Transformer (16 blocks)"; labeljust=l;
        style="filled,rounded"; fillcolor="#FCE4EC"; color="#C62828"; fontsize=10; margin=12;

        subgraph cluster_xfmr_block {
            label="  Each block (×16):"; labeljust=l;
            style="dashed,rounded"; color="#E53935"; fontsize=9; margin=10;

            dx_attn [label="1. Conditioned Self-Attention\nAdaLN(s_cond) → QKV\n16 heads, 48 head_dim\n+ pair bias from z_cond\n+ sigmoid gate from s_cond", fillcolor="#F8BBD0", color="#C62828"];
            dx_trans [label="2. Conditioned Transition\nAdaLN(s_cond) → SwiGLU (4×)\nworking dim 768\nsigmoid gate (bias init -2)", fillcolor="#F8BBD0", color="#C62828"];
        }
    }

    // ── Atom Attention Decoder ──
    subgraph cluster_dec {
        label="Atom Attention Decoder"; labeljust=l;
        style="filled,rounded"; fillcolor="#E0F2F1"; color="#00695C"; fontsize=10; margin=12;

        tok2atom_dec [label="token_to_atom\nLinear(768, 128, no bias)\nbroadcast token → atom", fillcolor="#B2DFDB", color="#00695C"];
        dec_attn [label="3× Local Attention Blocks\n4 heads, 32 head_dim\n+ 3× Conditioned Transitions\n(blocked Q=32, KV=128)", fillcolor="#80CBC4", color="#004D40"];
        to_pos [label="to_pos_updates\nLN(128) → Linear(128, 3, no bias)\n→ Δxyz per atom", fillcolor="#B2DFDB", color="#00695C"];
    }

    // ── EDM Preconditioning ──
    edm [label="EDM Output Formula\nD(x;σ) = c_skip·x + c_out·F_θ(c_in·x; σ)\n───────────────────────────────\nc_in = (σ²+σ_d²)^(-½)   c_skip = σ_d²/(σ²+σ_d²)\nc_out = σ·σ_d/√(σ²+σ_d²)   σ_data = 16", fillcolor="#F5F5F5", color="#424242"];

    // ── Output ──
    out [label="denoised atom coords\n[b, ds, n_atoms, 3]", fillcolor="#F5F5F5", color="#424242", shape=box];

    // ── Edges ──
    in_s_init -> cat_s;
    in_s_trunk -> cat_s;
    cat_s -> s_trans1;
    in_sigma -> fourier;
    s_trans1 -> fourier [label="+", arrowhead=none];
    fourier -> s_trans2 [label="+ σ embedding"];
    s_trans2 -> s_ln;

    in_z_init -> cat_z;
    in_z_trunk -> cat_z;
    cat_z -> z_trans;
    z_trans -> z_ln;

    s_ln -> tok2atom [label="s_cond"];
    in_atom_feats -> enc_attn [label="atom feats"];
    in_noised -> prev_pos;
    prev_pos -> enc_attn [label="+ pos embed"];
    tok2atom -> enc_attn [label="atom cond"];
    z_ln -> pair2ap [label="z_cond"];
    pair2ap -> enc_pair_upd;
    enc_pair_upd -> enc_attn [label="pair bias"];
    enc_attn -> enc_agg;

    enc_agg -> dx_attn [lhead=cluster_xfmr, label="token repr\n[768]"];
    s_ln -> dx_attn [label="s_cond\n(AdaLN + gate)"];
    z_ln -> dx_attn [label="z_cond\n(pair bias)", style=dotted];

    dx_attn -> dx_trans;

    dx_trans -> tok2atom_dec [lhead=cluster_dec, label="token repr\n[768]"];
    tok2atom_dec -> dec_attn;
    dec_attn -> to_pos;

    to_pos -> edm [label="F_θ output"];
    in_noised -> edm [label="x (skip)", style=dashed];
    edm -> out;
}
