digraph trunk {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box];
    edge [fontname="Helvetica", fontsize=8];
    bgcolor="white";
    pad=0.4;
    nodesep=0.3;
    ranksep=0.45;

    // ── Inputs ──
    in_s [label="single_initial [b, n, 384]", fillcolor="#E3F2FD", color="#1565C0"];
    in_z [label="pair_initial [b, n, n, 256]", fillcolor="#E3F2FD", color="#1565C0"];
    in_msa [label="MSA features [b, d, n, 64]", fillcolor="#E3F2FD", color="#1565C0"];
    in_templ [label="Template features [b, 4, n, n, 64]", fillcolor="#E3F2FD", color="#1565C0"];

    // ── Recycle projections ──
    subgraph cluster_recycle {
        label="Recycle Projections (×3 recycles)"; labeljust=l;
        style="dashed,rounded"; color="#888888"; fontsize=10; margin=12;
        rec_s [label="LN(384) → Linear(384, 384, no bias)\ntoken_single_recycle_proj", fillcolor="#F5F5F5", color="#616161"];
        rec_z [label="LN(256) → Linear(256, 256, no bias)\ntoken_pair_recycle_proj", fillcolor="#F5F5F5", color="#616161"];
    }

    // ── Template Embedder ──
    subgraph cluster_templ_emb {
        label="Template Embedder"; labeljust=l;
        style="filled,rounded"; fillcolor="#E0F7FA"; color="#00838F"; fontsize=10; margin=12;

        te_proj [label="proj_in\nLN(256) → Linear(256, 64, no bias)\npair → template dim", fillcolor="#B2EBF2", color="#00838F"];
        te_pf [label="2× PairformerBlock (dim 64)\n─ SwiGLU transition\n─ Triangle multiplication (both dirs)\n─ Triangle attention (8 heads, 16 hd)", fillcolor="#80DEEA", color="#00695C"];
        te_out [label="LN(64) → Linear(64, 256, no bias)\ntemplate → pair dim\nmean over 4 templates", fillcolor="#B2EBF2", color="#00838F"];
    }

    // ── MSA Module ──
    subgraph cluster_msa {
        label="MSA Module (4 iterations)"; labeljust=l;
        style="filled,rounded"; fillcolor="#F3E5F5"; color="#7B1FA2"; fontsize=10; margin=12;

        s2m [label="linear_s2m\nLinear(384, 64, no bias)\nsingle → first MSA row\n(once at start)", fillcolor="#E1BEE7", color="#7B1FA2"];

        subgraph cluster_msa_iter {
            label="  For i in 0..3:"; labeljust=l;
            style="dashed,rounded"; color="#9C27B0"; fontsize=9; margin=10;

            opm [label="outer_product_mean[i]\nMSA → pair update\nweight_ab [2,8,8,64]\nLN(512) → Linear(512, 256)", fillcolor="#CE93D8", color="#7B1FA2"];
            pt [label="pair_transition[i]\nSwiGLU (8×)\n256 → 2048 → 1024 → 256", fillcolor="#CE93D8", color="#7B1FA2"];

            msa_attn [label="if i < 3:\n  msa_pair_weighted_avg[i]\n  8 heads, 32 value_dim\n  pair → per-head attn weights", fillcolor="#BA68C8", color="#6A1B9A"];
            msa_trans [label="if i < 3:\n  msa_transition[i]\n  SwiGLU (8×)  64 → 512 → 256 → 64", fillcolor="#BA68C8", color="#6A1B9A"];

            tri_mul [label="triangular_multiplication[i]\nboth outgoing + incoming\nsigmoid gated", fillcolor="#CE93D8", color="#7B1FA2"];
            tri_att [label="triangular_attention[i]\nboth starting + ending node\n8 heads, 32 head_dim", fillcolor="#CE93D8", color="#7B1FA2"];
        }
    }

    // ── Pairformer Stack ──
    subgraph cluster_pf {
        label="Pairformer Stack (48 blocks)"; labeljust=l;
        style="filled,rounded"; fillcolor="#E8EAF6"; color="#283593"; fontsize=10; margin=12;

        subgraph cluster_pf_block {
            label="  Each block (×48):"; labeljust=l;
            style="dashed,rounded"; color="#3F51B5"; fontsize=9; margin=10;

            pf_pt [label="1. Pair Transition\nSwiGLU (4×)  256 → 1024 → 512 → 256", fillcolor="#C5CAE9", color="#283593"];
            pf_apb [label="2. Attention Pair Bias\n16 heads, 24 head_dim\npair → per-head attn bias\nsingleton gated output", fillcolor="#9FA8DA", color="#1A237E"];
            pf_st [label="3. Single Transition\nSwiGLU (4×)  384 → 1536 → 768 → 384", fillcolor="#C5CAE9", color="#283593"];
            pf_tm [label="4. Triangle Multiplication\nboth outgoing + incoming\nsigmoid gated", fillcolor="#C5CAE9", color="#283593"];
            pf_ta [label="5. Triangle Attention\nboth starting + ending node\n8 heads, 32 head_dim", fillcolor="#C5CAE9", color="#283593"];
        }
    }

    // ── Outputs ──
    out_s [label="single_trunk [b, n, 384]", fillcolor="#F5F5F5", color="#424242", shape=box];
    out_z [label="pair_trunk [b, n, n, 256]", fillcolor="#F5F5F5", color="#424242", shape=box];

    // ── Edges ──
    in_s -> rec_s;
    in_z -> rec_z;
    rec_s -> s2m [label="s += recycled"];
    rec_z -> te_proj [label="z += recycled"];

    in_templ -> te_proj [label="templates"];
    te_proj -> te_pf;
    te_pf -> te_out;
    te_out -> opm [label="z += template\nembedding"];

    in_msa -> s2m;
    s2m -> opm [label="MSA repr"];

    opm -> pt;
    pt -> msa_attn;
    msa_attn -> msa_trans;
    msa_trans -> tri_mul [label="(skipped\nat i=3)"];
    tri_mul -> tri_att;

    tri_att -> pf_pt [lhead=cluster_pf, label="single, pair\nrepresentations"];

    pf_pt -> pf_apb;
    pf_apb -> pf_st;
    pf_st -> pf_tm;
    pf_tm -> pf_ta;

    pf_ta -> out_s [label="single"];
    pf_ta -> out_z [label="pair"];
}
