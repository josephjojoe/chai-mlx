digraph blocked_attention {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box];
    edge [fontname="Helvetica", fontsize=8];
    bgcolor="white";
    pad=0.5;
    nodesep=0.3;
    ranksep=0.5;

    // ── Title ──
    title [label=<<B>Token-Atom Hierarchy &amp; Blocked Local Attention</B>>, shape=plaintext,
           fontsize=14, fontcolor="#1A237E"];

    // ── Hierarchy ──
    subgraph cluster_hier {
        label="Token–Atom Hierarchy"; labeljust=l;
        style="filled,rounded"; fillcolor="#E8F5E9"; color="#2E7D32"; fontsize=11; margin=14;

        tokens [label="Tokens  (n_tokens)\n─────────────────────────────────\n1 per residue (protein/nucleotide)\n1 per atom (ligands/modified res)\nModel sizes: 256 … 2048", fillcolor="#C8E6C9", color="#2E7D32"];
        atoms [label="Atoms  (n_atoms = 23 × n_tokens)\n───────────────────────────────────\nUp to 23 atoms per token\nn_atoms always divisible by 32\nPadding with atom_exists_mask", fillcolor="#A5D6A7", color="#1B5E20"];
        tok2atom [label="Mapping tensors:\natom_token_index → parent token\natom_within_token_index → slot\ntoken_reference_atom_index → repr atom", fillcolor="#C8E6C9", color="#2E7D32"];

        tokens -> atoms [label="23× expansion"];
        atoms -> tok2atom;
    }

    // ── Block geometry ──
    subgraph cluster_blocks {
        label="Blocked Local Attention Geometry"; labeljust=l;
        style="filled,rounded"; fillcolor="#E3F2FD"; color="#1565C0"; fontsize=11; margin=14;

        block_q [label="Query Block\n32 atoms (non-overlapping)\nnum_blocks = n_atoms / 32", fillcolor="#BBDEFB", color="#1565C0"];
        block_kv [label="KV Window\n128 atoms (centered on query)\nQ sits at positions 48–79\nwithin the 128-wide window", fillcolor="#90CAF9", color="#0D47A1"];
        overlap [label="Consecutive Windows\noffset by 32 (query stride)\noverlap by 96 atoms\n(128 − 32 = 96)", fillcolor="#BBDEFB", color="#1565C0"];
        boundary [label="Boundary Handling\nOut-of-range KV indices:\n→ marked invalid in kv_mask\n→ wrapped via % sequence_length\n→ excluded from attention", fillcolor="#BBDEFB", color="#1565C0"];
    }

    // ── Visual layout ──
    subgraph cluster_visual {
        label="Block Layout (one query block)"; labeljust=l;
        style="filled,rounded"; fillcolor="#FFF9C4"; color="#F57F17"; fontsize=11; margin=14;

        layout [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
            <TR>
                <TD BGCOLOR="#FFE0B2" COLSPAN="3">KV window (128 atoms)</TD>
            </TR>
            <TR>
                <TD BGCOLOR="#FFECB3" WIDTH="80">left context<BR/>48 atoms</TD>
                <TD BGCOLOR="#FF8A65" WIDTH="60"><B>Query block</B><BR/><B>32 atoms</B><BR/>positions 48–79</TD>
                <TD BGCOLOR="#FFECB3" WIDTH="80">right context<BR/>48 atoms</TD>
            </TR>
            <TR>
                <TD BGCOLOR="#FFF9C4" COLSPAN="3">← stride 32 →  overlap 96 with next window</TD>
            </TR>
        </TABLE>>, shape=plaintext];
    }

    // ── Pair features ──
    subgraph cluster_pair {
        label="Blocked Pair Features"; labeljust=l;
        style="filled,rounded"; fillcolor="#F3E5F5"; color="#7B1FA2"; fontsize=11; margin=14;

        pair_layout [label="Pair tensor shape:\n[b, num_blocks, 32, 128, feature_dim]\n     batch  block   Q    KV    channels", fillcolor="#E1BEE7", color="#7B1FA2"];
        pair_mask [label="block_atom_pair_mask\n[b, bl, 32, 128]\n= atom_q_mask ⊗ atom_kv_mask\n  ∧ kv_is_valid_mask", fillcolor="#E1BEE7", color="#7B1FA2"];
        pair_bias [label="blocked_pairs2blocked_bias\nLN(16) → Linear(16, n_blocks × n_heads)\nprojected to per-head attention bias\nper local block", fillcolor="#CE93D8", color="#6A1B9A"];

        pair_layout -> pair_mask;
        pair_mask -> pair_bias;
    }

    // ── Where used ──
    subgraph cluster_usage {
        label="Where Blocked Attention Is Used"; labeljust=l;
        style="dashed,rounded"; color="#888888"; fontsize=11; margin=14;
        node [fillcolor="#F5F5F5", color="#616161"];

        u1 [label="Token Input Embedder\n3 blocks, 4 heads, 32 hd"];
        u2 [label="Diffusion Atom Encoder\n3 blocks, 4 heads, 32 hd"];
        u3 [label="Diffusion Atom Decoder\n3 blocks, 4 heads, 32 hd"];
    }

    // ── Edges ──
    title -> tokens [style=invis];
    tokens -> block_q [ltail=cluster_hier, lhead=cluster_blocks, label="atom-level\nrepresentations"];
    block_q -> block_kv;
    block_kv -> overlap;
    overlap -> boundary;
    block_kv -> layout [ltail=cluster_blocks, lhead=cluster_visual];
    layout -> pair_layout [lhead=cluster_pair];
    pair_bias -> u1 [lhead=cluster_usage];
}
